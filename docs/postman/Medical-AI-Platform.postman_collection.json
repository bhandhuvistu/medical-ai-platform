{
  "info": {
    "name": "Medical AI Platform - Local",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "4dd7f1e0-9999-4c1c-b111-111111111111"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const resp = pm.response.json();",
              "if (resp.token) { pm.collectionVariables.set('token', resp.token); }",
              "pm.test('received token', function(){ pm.expect(resp.token).to.be.a('string'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"demo\",\n  \"password\": \"demo123\"\n}"
        }
      }
    },
    {
      "name": "Upload (sync)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/reports/upload",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "reports",
            "upload"
          ]
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "files",
              "type": "file",
              "src": ""
            }
          ]
        }
      }
    },
    {
      "name": "Submit (async)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/reports/submit",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "reports",
            "submit"
          ]
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "files",
              "type": "file",
              "src": ""
            }
          ]
        }
      }
    },
    {
      "name": "Status (async)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/reports/status/{{jobId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "reports",
            "status",
            "{{jobId}}"
          ]
        }
      }
    }
  ]
}